PORT=3000
# Em producao, troque pela URL real, por exemplo:
# BASE_URL=https://agendamento.suaempresa.com.br
BASE_URL=http://localhost:3000

# Token de API do Pipefy. Nunca coloque esse token na URL da 3C.
PIPEFY_TOKEN=cole_o_token_aqui
PIPEFY_PIPE_ID=123456789

# Opcional: se preencher, a URL da 3C deve enviar ?chave=esse_valor
INTEGRATION_SECRET=troque_por_uma_chave_grande

# Titulo padrao do card. Variaveis aceitas: {nome}, {telefone}, {protocolo}, {identificador}, {campanha}, {ramal}, {loja}
PIPEFY_CARD_TITLE=Agendamento 3C - {nome} - {telefone}

# Valores fixos para campos que a 3C nao envia.
# Use exatamente o texto/opcao do Pipefy ou o ID interno quando o Pipefy exigir.
PIPEFY_DEFAULT_VALUES={"tem_email":"❌ Não","plataforma":["317663860"],"agv":["307251915"],"loja":"📍 Nova Iguaçu"}

# Mapeia parametro recebido da 3C -> field_id do Pipefy.
# Campos da tela do Pipefy:
# Nome, Numero de telefone, Numero de contato 2, TEM E-MAIL?, PLATAFORMA,
# DATA DO AGENDAMENTO, AGV, Loja, Observacao.
# Troque os valores da direita pelos IDs reais dos campos se forem diferentes.
PIPEFY_FIELD_MAP={"nome":"nome","telefone":"n_mero_de_telefone","contato_2":"n_mero_de_contato_2","tem_email":"tem_e_mail","email":"email","plataforma":"plataforma","data_agendamento":"data_do_agendamento","agv":"agv","loja":"loja","observacao":"observa_o"}
