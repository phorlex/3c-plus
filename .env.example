PORT=3000
# Em producao, troque pela URL real, por exemplo:
# BASE_URL=https://agendamento.suaempresa.com.br
BASE_URL=http://localhost:3000

# Token de API do Pipefy. Nunca coloque esse token na URL da 3C.
PIPEFY_TOKEN=cole_o_token_aqui
PIPEFY_PIPE_ID=123456789

# Opcional: se preencher, a URL da 3C deve enviar ?chave=esse_valor
INTEGRATION_SECRET=troque_por_uma_chave_grande

# Titulo padrao do card. Variaveis aceitas: {nome}, {telefone}, {protocolo}, {identificador}, {campanha}, {ramal}
PIPEFY_CARD_TITLE=Agendamento 3C - {nome}

# Mapeia parametro recebido da 3C -> field_id do Pipefy.
# Troque os valores da direita pelos IDs reais dos campos do formulario inicial do Pipefy.
PIPEFY_FIELD_MAP={"nome":"nome_do_cliente","telefone":"telefone","protocolo":"protocolo_3c","identificador":"identificador_3c","campanha":"campanha_3c","ramal":"ramal_3c"}
