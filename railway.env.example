# Copie estas variaveis para a aba Variables do Railway.
# Nao suba este arquivo com valores reais.

NODE_ENV=production
BASE_URL=https://SEU-PROJETO.up.railway.app

PIPEFY_TOKEN=cole_o_token_aqui
PIPEFY_PIPE_ID=123456789
PIPEFY_CARD_TITLE=Agendamento 3C - {nome} - {telefone}
PIPEFY_FIELD_MAP={"nome":"nome","telefone":"numero_de_telefone","contato_2":"numero_de_contato_2","tem_email":"tem_e_mail","plataforma":"plataforma","data_agendamento":"data_do_agendamento","agv":"agv","loja":"loja","observacao":"observacao"}

INTEGRATION_SECRET=troque_por_uma_chave_grande
